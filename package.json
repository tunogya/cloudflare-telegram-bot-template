{
	"name": "cloudflare-tg-bot-template",
	"version": "1.0.0",
	"description": "A clean starter template for Telegram bots on Cloudflare Workers using Hono, grammY, D1, KV, and Queues.",
	"private": true,
	"dependencies": {
		"grammy": "^1.35.0",
		"hono": "4.11.1"
	},
	"devDependencies": {
		"@cloudflare/vitest-pool-workers": "0.10.11",
		"@types/node": "24.10.1",
		"typescript": "5.9.3",
		"vitest": "3.2.4",
		"wrangler": "4.56.0"
	},
	"scripts": {
		"cf-typegen": "wrangler types",
		"deploy": "wrangler deploy",
		"dev": "wrangler dev",
		"predeploy": "wrangler d1 migrations apply DB --remote",
		"migrate:local": "wrangler d1 migrations apply DB --local"
	}
}
